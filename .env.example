# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Anthropic API key — used for the LLM-driven 4Ms qualitative analysis
# and the zero-shot weekly paper-trading decision.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# SEC EDGAR User-Agent — required by SEC for all programmatic requests.
# Format: "<Your Name> <real monitored email>"
# Reference: https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=Your Name your-email@example.com

# Default LLM model used by the qualitative agent.
ANTHROPIC_MODEL=claude-opus-4-7

# Extended-thinking budget (in tokens) for Opus 4.7. Higher = more reasoning
# but more expensive (thinking tokens are billed at output rates). Default 32000.
ANTHROPIC_THINKING_BUDGET_TOKENS=32000

# Approximate character cap for prompts to fit within the 1M-token context window.
# 3,500,000 chars ≈ 875k tokens — leaves headroom for system prompt + tool defs.
ANTHROPIC_MAX_INPUT_CHARS=3500000

# Financial Modeling Prep API key — used to fetch earnings call transcripts for
# the management pipeline. Free tier allows ~250 requests/day; paid plans offer
# full history. Leave blank to fall back to SEC 8-K Exhibit 99.x scraping.
# Get one at https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Local cache root (relative to repo root). All EDGAR / price / LLM artifacts go here.
DATA_DIR=data

# Alpaca paper trading. Use paper keys only.
ALPACA_API_KEY_ID=
ALPACA_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Polygon is used for market data, news, and EUR/USD FX.
POLYGON_API_KEY=

# Paper-trading experiment accounting.
INITIAL_BUDGET_EUR=10000
EUR_USD_RATE_SOURCE=polygon
ITALY_CAPITAL_GAINS_TAX_RATE=0.26
PAPER_TRADING_LEDGER=paper_trading/ledger.jsonl
MAX_CANDIDATES_FOR_LLM=10
PRESELECT_COUNT=25
RESERVE_CASH_USD=5.0
